{
  "name": "Nebulite Script",
  "scopeName": "source.nebs",
  "patterns": [
    {
      "name": "comment.nebs",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.nebs",
      "begin": "(?<=\\b(?:echo|error)\\b)\\s",
      "end": "$",
      "patterns": [
        {
          "name": "variable.parameter.nebs",
          "match": "\\{[^}]*\\}"
        }
      ]
    },
    {
      "name": "variable.parameter.nebs",
      "match": "\\{[^}]*\\}"
    },
    {
      "name": "keyword.control.nebs",
      "match": "\\b(listMembersAndValues|play-sound-filtered|strCountAppearance|typeAsSimpleString|collision-detect|expression-help|selected-object|categoryLevel1|categoryLevel2|lPadNonNumeric|rPadNonNumeric|save-standards|bundleToArray|input-mapping|master-unlock|render-object|setFromResult|standard-file|always-clear|ensure-array|feature-test|formatNumber|removeMember|rng2argInt16|rng3argInt16|set-fixed-dt|toBoolString|typeAsNumber|typeAsString|audio-debug|deserialize|ensureArray|filterNulls|filterRegex|getMultiple|lPadNumeric|listMembers|rPadNumeric|set-integer|test-filter|--headless|basicValue|evaluation|filterGlob|imgui-view|input-wait|play-sound|push-front|pushNumber|set-string|startsWith|strCompare|--recover|add-clock|broadcast|constrain|dump-view|error-log|halt-once|keyDelete|pop-front|push-back|recursive|roundDown|serialize|setDouble|setString|substring|toBipolar|asString|category|contains|critical|document|endsWith|evaluate|function|functree|nonEmpty|pop-back|print-id|settings|show-fps|snapshot|toDouble|toString|variable|average|console|product|replace|require|reverse|rng2arg|rng3arg|roundUp|ruleset|set-fps|set-res|setBool|subspan|toLower|toUpper|always|assert|assign|delete|deload|equals|global|lStrip|length|listen|median|member|mirror|object|rStrip|reload|remove|setInt|stddev|string|toBool|unlock|array|clear|close|crash|debug|draft|error|fetch|first|parse|print|query|rmlui|round|spawn|state|strip|toInt|beep|copy|echo|eval|exit|help|json|lPad|last|load|lock|move|nand|once|open|push|rPad|root|save|sqrt|task|time|type|wait|warn|xnor|add|all|and|cam|cat|div|env|for|geq|get|key|leq|log|map|max|min|mod|mul|neq|nop|nor|not|off|pow|set|sgn|sub|sum|xor|at|eq|gt|if|ls|lt|on|or)\\b"
    },
    {
      "name": "markup.underline.link",
      "match": "\\./[^\\s|]+"
    },
    {
      "name": "constant.numeric.nebs",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}