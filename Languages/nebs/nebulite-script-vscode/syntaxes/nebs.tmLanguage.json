{
  "name": "Nebulite Script",
  "scopeName": "source.nebs",
  "patterns": [
    {
      "name": "comment.nebs",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.nebs",
      "begin": "(?<=\\b(?:echo|error)\\b)\\s",
      "end": "$",
      "patterns": [
        {
          "name": "variable.parameter.nebs",
          "match": "\\{[^}]*\\}"
        }
      ]
    },
    {
      "name": "variable.parameter.nebs",
      "match": "\\{[^}]*\\}"
    },
    {
      "name": "keyword.control.nebs",
      "match": "\\b(collision-detect|selected-object|assertNonEmpty|categoryLevel1|categoryLevel2|save-standards|set-background|master-unlock|always-clear|ensure-array|feature-test|renderobject|set-fixed-dt|standardfile|toBoolString|typeAsNumber|typeAsString|deserialize|ensureArray|getMultiple|set-integer|--headless|input-wait|push-front|set-string|--recover|add-clock|broadcast|halt-once|keyDelete|pop-front|push-back|serialize|category|critical|errorlog|function|functree|in-scope|pop-back|settings|show-fps|snapshot|toDouble|toString|variable|console|reverse|ruleset|set-fps|set-res|always|assert|delete|deload|global|length|listen|mirror|reload|return|toBool|unlock|clear|crash|debug|draft|error|fetch|first|parse|print|query|spawn|state|toInt|beep|copy|echo|eval|exit|help|json|last|load|lock|move|nebs|once|save|task|time|wait|warn|zoom|add|all|cam|env|for|get|key|log|map|mod|mul|nop|off|pow|set|at|if|on)\\b"
    },
    {
      "name": "markup.underline.link",
      "match": "\\./[^\\s|]+"
    },
    {
      "name": "constant.numeric.nebs",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}