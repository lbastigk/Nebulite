{
  "name": "Nebulite Script",
  "scopeName": "source.nebs",
  "patterns": [
    {
      "name": "comment.nebs",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.nebs",
      "begin": "(?<=\\b(?:echo|error)\\b)\\s",
      "end": "$",
      "patterns": [
        {
          "name": "variable.parameter.nebs",
          "match": "\\{[^}]*\\}"
        }
      ]
    },
    {
      "name": "variable.parameter.nebs",
      "match": "\\{[^}]*\\}"
    },
    {
      "name": "keyword.control.nebs",
      "match": "\\b(collision-detect|selected-object|categoryLevel1|categoryLevel2|save-standards|set-background|master-unlock|setFromResult|always-clear|ensure-array|feature-test|removeMember|renderobject|set-fixed-dt|standardfile|toBoolString|typeAsNumber|typeAsString|deserialize|ensureArray|filterNulls|getMultiple|listMembers|set-integer|--headless|basicValue|filterGlob|input-wait|push-front|pushNumber|set-string|--recover|add-clock|broadcast|halt-once|keyDelete|pop-front|push-back|roundDown|serialize|setDouble|setString|substring|category|critical|errorlog|function|functree|in-scope|nonEmpty|pop-back|settings|show-fps|snapshot|toDouble|toString|variable|console|replace|require|reverse|roundUp|ruleset|set-fps|set-res|setBool|subspan|toLower|toUpper|always|assert|delete|deload|global|length|listen|mirror|object|reload|return|setInt|toBool|unlock|array|clear|crash|debug|draft|error|fetch|first|parse|print|query|round|spawn|state|strip|toInt|beep|copy|echo|eval|exit|help|json|last|load|lock|move|once|push|root|save|sqrt|task|time|type|wait|warn|zoom|add|all|cam|div|env|for|get|key|log|map|mod|mul|nop|off|pow|set|sub|at|if|on)\\b"
    },
    {
      "name": "markup.underline.link",
      "match": "\\./[^\\s|]+"
    },
    {
      "name": "constant.numeric.nebs",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}