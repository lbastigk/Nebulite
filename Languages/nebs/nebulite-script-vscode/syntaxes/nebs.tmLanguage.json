{
  "name": "Nebulite Script",
  "scopeName": "source.nebs",
  "patterns": [
    {
      "name": "comment.nebs",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.nebs",
      "begin": "(?<=\\b(?:echo|error)\\b)\\s",
      "end": "$",
      "patterns": [
        {
          "name": "variable.parameter.nebs",
          "match": "\\{[^}]*\\}"
        }
      ]
    },
    {
      "name": "variable.parameter.nebs",
      "match": "\\{[^}]*\\}"
    },
    {
      "name": "keyword.control.nebs",
      "match": "\\b(strCountAppearance|collision-detect|expression-help|selected-object|categoryLevel1|categoryLevel2|save-standards|set-background|input-mapping|master-unlock|setFromResult|always-clear|ensure-array|feature-test|removeMember|renderobject|rng2argInt16|rng3argInt16|set-fixed-dt|standardfile|toBoolString|typeAsNumber|typeAsString|deserialize|ensureArray|filterNulls|filterRegex|getMultiple|listMembers|set-integer|--headless|basicValue|evaluation|filterGlob|input-wait|push-front|pushNumber|set-string|startsWith|strCompare|to_bipolar|--recover|add-clock|broadcast|constrain|halt-once|keyDelete|pop-front|push-back|recursive|roundDown|serialize|setDouble|setString|substring|autotype|category|contains|critical|endsWith|errorlog|evaluate|function|functree|in-scope|nonEmpty|pop-back|settings|show-fps|snapshot|toDouble|toString|variable|average|console|execute|product|replace|require|reverse|rng2arg|rng3arg|roundUp|ruleset|set-fps|set-res|setBool|subspan|toLower|toUpper|always|assert|delete|deload|equals|global|lStrip|length|listen|median|member|mirror|object|rStrip|reload|return|setInt|stddev|toBool|unlock|array|clear|close|crash|debug|draft|enter|error|fetch|first|parse|print|query|round|spawn|state|strip|toInt|beep|copy|down|echo|eval|exit|help|json|last|load|lock|move|nand|once|open|push|root|save|sqrt|task|text|time|type|wait|warn|xnor|zoom|add|all|and|cam|div|env|for|geq|get|key|leq|log|map|max|min|mod|mul|neq|nop|nor|not|off|pow|set|sgn|sub|sum|xor|at|eq|gt|if|lt|on|or|up)\\b"
    },
    {
      "name": "markup.underline.link",
      "match": "\\./[^\\s|]+"
    },
    {
      "name": "constant.numeric.nebs",
      "match": "\\b\\d+(\\.\\d+)?\\b"
    }
  ]
}