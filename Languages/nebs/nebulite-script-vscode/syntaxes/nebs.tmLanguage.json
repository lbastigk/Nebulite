{
  "name": "Nebulite Script",
  "scopeName": "source.nebs",
  "patterns": [
    {
      "name": "comment.nebs",
      "match": "#.*$"
    },
    {
      "name": "string.quoted.nebs",
      "begin": "(?<=\\b(?:echo|error)\\b)\\s",
      "end": "$",
      "patterns": [
        {
          "name": "variable.parameter.nebs",
          "match": "\\{[^}]*\\}"
        }
      ]
    },
    {
      "name": "variable.parameter.nebs",
      "match": "\\{[^}]*\\}"
    },
    {
      "name": "keyword.control.nebs",
      "match": "\\b(listMembersAndValues|play-sound-filtered|context-evaluation|strCountAppearance|typeAsSimpleString|case-insensitive|collision-detect|expression-help|fetch-container|key-combination|selected-object|case-sensitive|categoryLevel1|categoryLevel2|lPadNonNumeric|rPadNonNumeric|save-standards|bundleToArray|input-mapping|master-unlock|render-object|standard-file|always-clear|ensure-array|feature-test|filterCustom|for-progress|formatNumber|injectScript|removeMember|rng2argInt16|rng3argInt16|set-fixed-dt|toBoolString|typeAsNumber|typeAsString|audio-debug|deserialize|ensureArray|filterNulls|filterRegex|lPadNumeric|listMembers|numerically|rPadNumeric|set-integer|test-filter|unreachable|--headless|basicValue|capitalize|fetch-name|filterGlob|imgui-view|input-wait|must-throw|play-sound|push-front|pushNumber|set-string|startsWith|strCompare|--recover|add-clock|broadcast|constrain|dump-view|enumerate|error-log|halt-once|keyDelete|pop-front|push-back|recursive|roundDown|serialize|setDouble|setString|substring|toBipolar|category|contains|document|endsWith|evaluate|fetch-id|function|functree|nonEmpty|pop-back|print-id|settings|show-fps|snapshot|toDouble|toString|variable|average|ceiling|console|default|forward|product|reparse|replace|require|reverse|rng2arg|rng3arg|roundUp|ruleset|set-fps|set-res|setBool|subspan|toLower|toUpper|always|assert|assign|custom|delete|deload|equals|exists|global|invoke|lStrip|length|listen|median|member|mirror|object|rStrip|reload|remove|setInt|stddev|strLen|string|toBool|unlock|array|clear|close|crash|debug|draft|empty|error|fetch|first|floor|match|other|parse|print|query|regex|rmlui|round|spawn|state|store|strip|throw|toInt|beep|copy|echo|eval|exit|grid|help|iota|json|lPad|last|list|load|lock|move|nand|once|open|push|rPad|root|save|sort|sqrt|task|time|type|view|wait|warn|xnor|add|all|and|cam|cat|div|env|for|geq|get|int|key|leq|log|map|max|min|mod|mul|neq|nop|nor|not|off|pow|set|sgn|sub|sum|xor|at|eq|gt|if|ls|lt|on|or)\\b"
    },
    {
      "name": "markup.underline.link",
      "match": "\\./[^\\s|]+"
