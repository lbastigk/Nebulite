{
    "topic": "",
    "condition": "$( {global.input.up} + {global.input.down} + {global.input.left} + {global.input.right} )",
    "action": {
        "assign": [
            "self.anmimation.Direction = $( {global.input.up} * 16 + {global.input.right} * 32 * not({global.input.up}) + {global.input.left} * 48 * not({global.input.up}) * not({global.input.right}) )"
        ],
        "functioncall": {
            "global": [],
            "self": [],
            "other": []
        }
    }
}