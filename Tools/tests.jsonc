{
    "binaries" : [
        "./bin/Nebulite --headless",
        "./bin/Nebulite_Debug --headless",
        "DXVK_LOG_LEVEL=none WINEDEBUG=-all wine ./bin/Nebulite.exe --headless",
        "DXVK_LOG_LEVEL=none WINEDEBUG=-all wine ./bin/Nebulite_Debug.exe --headless"
    ],
    "ignore_lines": { // Lines to ignore in the output, supports wildcards (*)
        "cout" : [
            "Loading task list from file*", // Every time a task list is loaded, this is printed. Instead of adding the line to every test, we can just ignore it globally.
            "Loaded font face*"             // From RmlUi on initialization
        ],
        "cerr" : [
            "*wined3d_swapchain_resize_buffers*"   // Wine-related debug message
        ]
    },
    "tests": [
        //---------------------------------------
        // Domain tests
        "Tools/Tests/Domain/basics.json",
        "Tools/Tests/Domain/output.json",
        "Tools/Tests/Domain/deserialization.json",
        "Tools/Tests/Domain/ruleset.json",
        //---------------------------------------
        // Tests from the featureTest DomainModule, for calling hardcoded test functions
        "Tools/Tests/Integrated/funcTree.json",         // Basic functree initialization and execution tests
        "Tools/Tests/Integrated/keyCombination.json",   // JSON key combinations, making sure there are no trailing dots or other weirdness in key combinations: key.addMember("a").addIndex(3)...
        "Tools/Tests/Integrated/findParentKey.json",    // Finding the parent of a given key is important for cache invalidation
        "Tools/Tests/Integrated/context.json",          // Tests access to self/other/global context-model
        //---------------------------------------
        // Expression tests
        "Tools/Tests/Expression/basics.json",
        "Tools/Tests/Expression/math.json",
        "Tools/Tests/Expression/nestedEvaluation.json",
        "Tools/Tests/Expression/types.json",
        //---------------------------------------
        // Assignment tests
        "Tools/Tests/Assignment/basics.json",
        //---------------------------------------
        // FuncTree tests
        "Tools/Tests/Functional/bindingCollisionDetection.json",
        "Tools/Tests/Functional/completion.json",
        //---------------------------------------
        // JSON tests
        "Tools/Tests/JSON/Basics.json",
        "Tools/Tests/JSON/Caching.json",
        "Tools/Tests/JSON/ComplexData.json",
        "Tools/Tests/JSON/TransformationBasics.json", // Test of basic transformation syntax, not specific to any particular transformation
        //---------------------------------------
        // JSON transformation tests
        "Tools/Tests/JSON/Transformations/Arithmetic.json",
        "Tools/Tests/JSON/Transformations/Array.json",
        "Tools/Tests/JSON/Transformations/Assertions.json",
        "Tools/Tests/JSON/Transformations/Boolean.json",
        "Tools/Tests/JSON/Transformations/Casting.json",
        "Tools/Tests/JSON/Transformations/Collection.json",
        "Tools/Tests/JSON/Transformations/Debug.json",
        "Tools/Tests/JSON/Transformations/Domain.json",
        "Tools/Tests/JSON/Transformations/General.json",
        "Tools/Tests/JSON/Transformations/Requirements.json",
        "Tools/Tests/JSON/Transformations/Sort.json",
        "Tools/Tests/JSON/Transformations/Statistics.json",
        "Tools/Tests/JSON/Transformations/String.json",
        "Tools/Tests/JSON/Transformations/Types.json",
        //---------------------------------------
        // Ruleset tests
        "Tools/Tests/Rulesets/DebugUtils.json",
        "Tools/Tests/Rulesets/selfOtherGlobalInteraction.json",
        //---------------------------------------
        // GlobalSpace tests
        "Tools/Tests/GlobalSpace/time.json",
        "Tools/Tests/GlobalSpace/mirror_draft_selection.json",
        //---------------------------------------
        // Environment Tests
        "Tools/Tests/Environment/basics.json",
        //---------------------------------------
        // Renderer Tests
        "Tools/Tests/Renderer/tiling.json",
        "Tools/Tests/Renderer/io.json",
        //---------------------------------------
        // RmlUi tests
        "Tools/Tests/RmlUi/basics.json",
        //---------------------------------------
        // Misc tests, sort, expand and diversify later
        "Tools/Tests/scenes.json"
    ],
    "timeout": 240 // Coverage reports can take a while to generate, so we set a higher timeout for all tests. Later on we should set a separate timeout for coverage tests, but for now this is good enough.
}