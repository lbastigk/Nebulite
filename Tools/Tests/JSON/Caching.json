[
    {
        "command": [
            "# Test if no previous value is cached when using setSubDoc when using assign",
            "# If there is any 3 left in the output, there is a problem",
            "set test.val 3",
            "set test.val2 4",
            "assign global:test.val = {global:test.val2}",
            "print test","print test.val",
            "eval echo {global:test}",
            "eval echo {global:test.val}",
            "exit"
        ],
        "expected": {
            "cout": [
                "{",
                "    \"val\": \"4\",",
                "    \"val2\": \"4\"",
                "}",
                "4",
                "{object}",
                "4"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "task TaskFiles/Tests/JSON/stableDoublePointerOverride.nebs"
        ],
        "expected": {
            "cout": [
                "Base state: time is an object, time.dt is a value:",
                "object",
                "object",
                "value",
                "value:float:64",
                "1.) Setting global:time to a simple value:",
                "value",
                "value:string:15",
                "null",
                "null",
                "2.) After wait, time should be an object again, and time.dt should be a value again:",
                "object",
                "object",
                "value",
                "value:float:64"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "time set-fixed-dt 1",
            "set-fps 60",
            "wait 1",
            "eval echo {global:time}",
            "wait 1",
            "set time someOverrideValue",
            "wait 1",
            "# TODO: expected should be that the last eval returns object again, as the time module overrides the value",
            "eval echo {global:time}",
            "exit"
        ],
        "expected": {
            "cout": [
                "{object}",
                "{object}"
            ],
            "cerr": []
        }
    },
    {
        "command":[
            "eval echo {global:|typeAsString|ensureArray|print}"
        ],
        "expected":{
            "cout":[
                "[",
                "    \"object:4\"",
                "]",
                "[array]"
            ],
            "cerr":[]
        }
    }
]