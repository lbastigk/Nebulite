[
    {
        "command": [
            "# Upper and Lower Case Transformation Test",
            "set test.string HelloWorld",
            "eval echo {global.test.string|toUpper}",
            "eval echo {global.test.string|toLower}",
            "exit"
        ],
        "expected": {
            "cout": [
                "HELLOWORLD",
                "helloworld"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# Substring Extraction Test",
            "set test.string HelloWorld",
            "eval echo {global.test.string|substring 0 5}",
            "eval echo {global.test.string|substring 5 5}",
            "exit"
        ],
        "expected": {
            "cout": [
                "Hello",
                "World"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# String Replacement Test",
            "set test.string HelloWorld",
            "eval echo {global.test.string|replace World Universe}",
            "eval echo {global.test.string|replace Hello Hi}",
            "exit"
        ],
        "expected": {
            "cout": [
                "HelloUniverse",
                "HiWorld"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# Trailing whitespaces are difficult to handle in command line arguments",
            "# Instead, we test the strip transformation in a dedicated .nebs file",
            "task TaskFiles/Tests/Transformations/strip.nebs"
        ],
        "expected": {
            "cout": [
                "  HelloWorld  ",
                "HelloWorld",
                "HelloWorld  ",
                "  HelloWorld"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# String count appearance",
            "set test.string HelloWorldHello",
            "eval echo {global.test.string|strCountAppearance Hello}",
            "exit"
        ],
        "expected": {
            "cout": [
                "2"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# String equality",
            "set test.string HelloWorld",
            "eval nop {global.test.string|strCompare equals HelloWorld|print}",
            "eval nop {global.test.string|strCompare equals Hello|print}",
            "eval nop {global.test.string|strCompare equals helloworld|print}",
            "exit"
        ],
        "expected": {
            "cout": [
                "true",
                "false",
                "false"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# String contains",
            "set test.string HelloWorld",
            "eval nop {global.test.string|strCompare contains Hello|print}",
            "eval nop {global.test.string|strCompare contains World|print}",
            "eval nop {global.test.string|strCompare contains Hi|print}",
            "exit"
        ],
        "expected": {
            "cout": [
                "true",
                "true",
                "false"
            ],
            "cerr": []
        }
    },
    {
        "command": [
            "# String starts with and ends with",
            "set test.string HelloWorld",
            "eval nop {global.test.string|strCompare startsWith Hello|print}",
            "eval nop {global.test.string|strCompare startsWith World|print}",
            "eval nop {global.test.string|strCompare endsWith World|print}",
            "eval nop {global.test.string|strCompare endsWith Hello|print}",
            "exit"
        ],
        "expected": {
            "cout": [
                "true",
                "false",
                "true",
                "false"
            ],
            "cerr": []
        }
    }
]