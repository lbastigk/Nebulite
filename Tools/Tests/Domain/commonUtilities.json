[
    {
        "command": "echo Hello, World!",
        "expected": { "cout": ["Hello, World!"], "cerr": [] }
    },
    {
        "command": "eval echo $i(1+1)",
        "expected": { "cout": ["2"], "cerr": [] }
    },
    {
        "command": "nop",
        "expected": { "cout": [], "cerr": [] }
    },
    {
        "command": "assert $(eq(2,1+1))",
        "expected": { "cout": [], "cerr": [] }
    },
    {
        "command": "for i 1 5 echo Iteration {i}",
        "expected": {
            "cout": [
                "Iteration 1",
                "Iteration 2",
                "Iteration 3",
                "Iteration 4",
                "Iteration 5"
            ],
            "cerr": []
        }
    },
    {
        "command": "if $(eq(1+1,2)) then echo true",
        "expected": { "cout": ["true"], "cerr": [] }
    },
    {
        "command": "if $(eq(1+1,3)) then echo false",
        "expected": { "cout": [], "cerr": [] }
    },
    {
        "command": "task TaskFiles/Tests/JSON/Assign.nebs",
        "expected": { "cout": [
            "[",
            "    \"t_ms\",",
            "    \"dt_ms\"",
            "]"
        ], "cerr": [] }
    },
    {
        "command": "print physics.G",
        "expected": { "cout": ["6.6743e-11"], "cerr": [] }
    },
    {
        "command": "print-id",
        "expected": { "cout": ["0"], "cerr": [] }
    },
    {
        "command": "warn This is a warning!",
        "expected": { "cout": [], "cerr": ["This is a warning!"] }
    },
    {
        "command": "set-fps 60 ; wait 1; error Aborting due to error!",
        "expected": { "cout": [], "cerr": ["Aborting due to error!"], "ignore_exit": true }
    },
    {
        "command": [
            "if $(0) then echo This will not print",
            "if $(1) then echo This will print",
            "if $(0) echo This will not print either",
            "if $(1) echo This will print as well",
            "if $(1 + 1) then echo This will also print",
            "if $(0 + 0) then echo This will not print"
        ],
        "expected": {
            "cout": [
                "This will print",
                "This will print as well",
                "This will also print"
            ],
            "cerr": []
        }
    },
    {
        "command": "task TaskFiles/Tests/Domain/General/must-throw.nebs",
        "expected": { "cout": [], "cerr": [] }
    }
]