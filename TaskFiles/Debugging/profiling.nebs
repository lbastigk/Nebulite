# -----------------------------------------------------------------------------
# profiling.nebs
#
# Short description:
#   Minimal task script intended for profiling performance of specific scenes
#
# Usage:
#   make profiling
#
# Notes:
#   - You may modify this file to suit your profiling needs
# -----------------------------------------------------------------------------
echo "Starting profiling.nebs"
# -----------------------------------------------------------------------------

set-fps 10000

set settings.n 40 # Before loading the scene, set the number of objects (n*n)
task TaskFiles/Benchmarks/gravity_XL_unlimited.nebs
wait 1
imgui-view on

wait 2000
exit

#task TaskFiles/Benchmarks/transformation.nebs
