echo This test is used to see if the engine handles objects out of bounds
echo usually, the culprit is a pointer issue
echo
echo
set-res 500 500
set-fps 600
time set-fixed-dt 100 # ms

set waitTime 30

# No debug view
imgui-view off

###########################################
# Test 1: no rulesets
echo spawning two inside bounds
spawn ./Resources/Renderobjects/standard.jsonc|posX=100|posY=100
spawn ./Resources/Renderobjects/standard.jsonc|posX=100|posY=400
echo spawning two outside bounds
spawn ./Resources/Renderobjects/standard.jsonc|posX=2000|posY=100
spawn ./Resources/Renderobjects/standard.jsonc|posX=2000|posY=400
eval wait {global:waitTime}

# Check count, then deload environment and check if all objects are deleted properly
fetch-container
eval nop {global:renderer.environment.debug.container.objectCount.total|assert equals int 4}
env deload
wait 1
fetch-container
eval nop {global:renderer.environment.debug.container.objectCount.total|assert equals int 0}
eval wait {global:waitTime}

###########################################
# Test 2: with rulesets
echo spawning two inside bounds
spawn ./Resources/Renderobjects/Planets/obj1.jsonc|posX=100|posY=100|physics.vX=0|physics.vY=1000
spawn ./Resources/Renderobjects/Planets/obj1.jsonc|posX=100|posY=400|physics.vX=0|physics.vY=1000
echo spawning two outside bounds
spawn ./Resources/Renderobjects/Planets/obj1.jsonc|posX=2000|posY=100|physics.vX=0|physics.vY=1000
spawn ./Resources/Renderobjects/Planets/obj1.jsonc|posX=2000|posY=400|physics.vX=0|physics.vY=1000
eval wait {global:waitTime}

# Check count, then deload environment and check if all objects are deleted properly
fetch-container
eval nop {global:renderer.environment.debug.container.objectCount.total|assert equals int 4}
env deload
wait 1
fetch-container
eval nop {global:renderer.environment.debug.container.objectCount.total|assert equals int 0}
eval wait {global:waitTime}

exit
