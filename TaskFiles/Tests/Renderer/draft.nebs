# Test draft usage
set-fps 60

# Build up draft object and spawn it
draft parse set posX 666
draft parse set posY 555
draft spawn

# Get that object
wait 1
selected-object get 1
wait 1

# Assert that the values are correct
draft parse eval nop {self:posX|assert equals int 666}
draft parse eval nop {self:posY|assert equals int 555}
must-throw draft parse eval nop {self:posX|assert equals int 444}

exit 