# Set results, calculated using np.fft
set compare[0] 0.67
set compare[1] -0.33
set compare[2] 0.33
set compare[3] -0.33
set compare[4] 0.00
set compare[5] 0.00
set compare[6] 0.33
set compare[7] 0.00

# Calculate
capture result.raw apply-transfer-function-frequency-domain 1 0 0 0 0 0 0 0 --num 1 0 1 --den 1 1 0 1
assign global:result.formatted = {global:result.raw|at 0|split|map formatNumber .2f}

# Validate
eval nop {global:result.formatted|length|assert equals int 8}
for i 0 7 if $(not({global:|strCompare members compare[{i}] result.formatted[{i}]})) then throw "TF output mismatch at index {i}"

exit