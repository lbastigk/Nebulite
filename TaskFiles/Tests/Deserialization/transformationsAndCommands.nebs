#==========================================================
# Tests transformations and commands during deserialization
#==========================================================

# The difference:
# - A transformation acts on the JSON document
# - A command is parsed into the domain after deserialization

# Classic deserialization:
spawn ./Resources/Renderobjects/standard.jsonc \
    |set posX 100 \
    |set posY 100

# New style deserialization:
spawn {./Resources/Renderobjects/standard.jsonc|echo TEST}\
    |set posX 300 \
    |set posY 100
# Should print TEST during deserialization

# See if the positions are correct
selected-object get 1
selected-object parse print posX # Expect 100
selected-object parse print posY # Expect 100
selected-object get 2
selected-object parse print posX # Expect 300
selected-object parse print posY # Expect 100

exit