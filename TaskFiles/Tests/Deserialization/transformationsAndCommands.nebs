#==========================================================
# Tests transformations and commands during deserialization
#==========================================================

# The difference:
# - A transformation acts on the JSON document
# - A command is parsed into the domain after deserialization

# Classic deserialization: Link and commands
spawn ./Resources/Renderobjects/standard.jsonc \
    |set posX 123 \
    |set posY 234

# New style deserialization: Object with in-object transformations and commands
spawn {./Resources/Renderobjects/standard.jsonc|setString foo bar}\
    |set posX 345 \
    |set posY 456

# See if values are correct
selected-object get 1
selected-object parse eval nop {self:posX|assert equals int 123}
selected-object parse eval nop {self:posY|assert equals int 234}
selected-object get 2
selected-object parse eval nop {self:foo|assert equals string bar}
selected-object parse eval nop {self:posX|assert equals int 345}
selected-object parse eval nop {self:posY|assert equals int 456}

exit