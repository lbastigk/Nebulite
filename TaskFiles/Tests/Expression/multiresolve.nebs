###################################################
# Test multi-resolve within a Nebulite expression
# Resolves inner expressions first
# unless an evaluation-delay is specified,
# which is not tested here
###################################################

# Setup workspace
set foo.value1.value2 final_value
set fooPath value1.value2   # describes a path to a value in foo
set partialPath lue1.value2 # To check if multi-resolve works even if we insert mid-key and not after a dot

###################################################
# Normal resolution for comparison, hardcoded path
eval nop {global:foo.value1.value2|assert equals string final_value}

###################################################
# Now, try to resolve using multi-resolve,
# by using the value of fooPath as part of the path to resolve
eval nop {global:foo.{global:fooPath}|assert equals string final_value}

###################################################
# Now test a partial path
eval nop {global:foo.va{global:partialPath}|assert equals string final_value}