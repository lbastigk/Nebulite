###############################
# Setup a scene
# Two Suns attracting each other, with mirrors enabled to see if the mirror works
set-fps 100
set physics.G 10 # Gravity constant, high value for testing
time set-fixed-dt 1
spawn ./Resources/Renderobjects/Planets/sun.jsonc \
    |set posX 750 \
    |set posY 500 \
    |set text.str SUN1 \
    |set physics.mass 1000
spawn ./Resources/Renderobjects/Planets/sun.jsonc \
    |set posX 250 \
    |set posY 500 \
    |set text.str SUN2 \
    |set physics.mass 1000

###############################
# Setup mirror
selected-object get 1
selected-object parse mirror on
selected-object get 2
selected-object parse mirror on
wait 1

###############################
# Render some frames, then check mirrors
# Mirrors should be equal, besides:
# - x-value is different
# - velocity is opposite in x-direction
# - acceleration is opposite in x-direction
wait 10

# Check obj1 values
assert $(lt({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.posX},750))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.posY},500))
assert $(lt({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.physics.vX},0))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.physics.vY},0))
assert $(lt({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.physics.aX},0))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.physics.aY},0))

# Check obj2 values
assert $(gt({global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.posX},250))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.posY},500))
assert $(gt({global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.physics.vX},0))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.physics.vY},0))
assert $(gt({global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.physics.aX},0))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.physics.aY},0))

# Check if both objects attract each other with the same force (opposite acceleration and velocity in x-direction)
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.physics.aX},-{global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.physics.aX}))
assert $(eq({global:providedScope.module.domain.renderObject.mirror.renderObject.idx1.physics.vX},-{global:providedScope.module.domain.renderObject.mirror.renderObject.idx2.physics.vX}))

exit