set-fps 60
wait 1

# Now we have access to renderer values like time etc.
# Test if we can manipulate data and assign it as a json object
assign global:testValue = {global:time|require type object|filterGlob *_ms|listMembers|reverse}

eval nop {global:testValue|assert type array}
eval nop {global:testValue|length|assert equals int 2}
eval nop {global:testValue|at 0|assert equals string t_ms}
eval nop {global:testValue|at 1|assert equals string dt_ms}

exit