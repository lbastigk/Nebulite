set arr[0] 1
set arr[1] 2
set arr[2] 3
set arr[10].var 11
set arr[11] 12
set obj.keyfoobar foobar
set obj.keybarfoo barfoo
set obj.keybarbaz barbaz
eval nop {global.arr|filterGlob \[1*\]|print}
eval nop {global.arr|filterGlob \[1*\]|filterNulls|print}
eval nop {global.obj|filterGlob keybar*|print}
exit