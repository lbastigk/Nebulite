set arr[0][8] 8
set arr[1][6] 6
set arr[2][7] 7
set arr[3][5] 5
set arr[4][3] 3
set arr[5][0] 0
set arr[6][9] 9
assign global:result = {global:arr|sort custom (gt({self:|length},{other:|length}))}
assert $(eq({global:result[0]|length},1))
assert $(eq({global:result[1]|length},4))
assert $(eq({global:result[2]|length},6))
assert $(eq({global:result[3]|length},7))
assert $(eq({global:result[4]|length},8))
assert $(eq({global:result[5]|length},9))
assert $(eq({global:result[6]|length},10))
exit