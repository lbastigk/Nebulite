# Check Nebulite properly handles nested transformations.
set workspace.arr[0] 1
set workspace.arr[1] 2
set workspace.arr[2] 3

# Old version using assign:
eval nop {global:workspace|setFromResult arraySize {1!self:arr|length|toInt}|print}

# New version using assign:
eval nop {global:workspace|assign self:arraySize = {1!self:arr|length|toInt}|print}
eval nop {|assign self:key = $i(1+1)|print}

exit