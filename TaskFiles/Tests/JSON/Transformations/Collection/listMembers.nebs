# List Members function

# Array
set arr[0] 1
set arr[1] 2
set arr[2] 3

# Object
set obj.key1 value1
set obj.key2 value2
set obj.key3 value3

# List members
assign global:result.arr = {global:arr|listMembers}
assign global:result.obj = {global:obj|listMembers}

# Verify
eval nop {global:result.arr|assert type array}
eval nop {global:result.arr|length|assert equals int 3}
eval nop {global:result.arr|get [0]|assert equals string [0]}
eval nop {global:result.arr|get [1]|assert equals string [1]}
eval nop {global:result.arr|get [2]|assert equals string [2]}

eval nop {global:result.obj|assert type array}
eval nop {global:result.obj|length|assert equals int 3}
eval nop {global:result.obj|get [0]|assert equals string key1}
eval nop {global:result.obj|get [1]|assert equals string key2}
eval nop {global:result.obj|get [2]|assert equals string key3}

exit