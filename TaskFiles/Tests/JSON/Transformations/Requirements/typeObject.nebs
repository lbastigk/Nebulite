# Assert that a value is an object
set basicValue value1
set arrayValue[0] value1
set arrayValue[1] value2
set objectValue.key1 value1
set objectValue.key2 value2

# Scenario 1: must fail
assign global:result = {global:basicValue|require type object|unreachable}
eval nop {global:result|assert empty}
assign global:result = {global:arrayValue|require type object|unreachable}
eval nop {global:result|assert empty}

# Scenario 2: success
assign global:result = {global:objectValue|require type object}
eval nop {global:result|assert type object}