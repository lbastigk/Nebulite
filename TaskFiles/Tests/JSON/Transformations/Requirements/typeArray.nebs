# Test assertion that a value is an array
set notAnArray "This is not an array"
set isAnArray[0] value1
set isAnArray[1] value2

# Scenario 1: must fail
assign global:result = {global:notAnArray|require type array|unreachable}
eval nop {global:result|assert empty}

# Scenario 2: success
assign global:result = {global:isAnArray|require type array}
eval nop {global:result|assert type array}