# Test if a value matches a regex - must throw
set v MyTestString

# Scenario 1: must fail
assign global:result = {global:v|require match regex ^My.*string$|unreachable}
eval nop {global:result|assert empty}

# Scenario 2: success
assign global:result = {global:v|require match regex ^My.*String$}
eval nop {global:result|assert equals string MyTestString}
