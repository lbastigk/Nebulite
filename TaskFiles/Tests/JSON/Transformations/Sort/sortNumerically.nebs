# Setup array
set arr[0] 8
set arr[1] 6
set arr[2] 7
set arr[3] 5
set arr[4] 3
set arr[5] 0
set arr[6] 9

# Sort
assign global:result = {global:arr|sort numerically|map toInt}

# Verify
assert $(eq({global:result[0]},0))
assert $(eq({global:result[1]},3))
assert $(eq({global:result[2]},5))
assert $(eq({global:result[3]},6))
assert $(eq({global:result[4]},7))
assert $(eq({global:result[5]},8))
assert $(eq({global:result[6]},9))

exit