# Testing string contains transformation

# Setup test strings
set test.string1 HelloWorldHello
set test.string2 Hello World, Hello Nebulite!

# count appearance and verify

# must be true
assign global:result.mustBeTrue[0] = {global:test.string1|strCompare contains Hello}
assign global:result.mustBeTrue[1] = {global:test.string2|strCompare contains Nebulite!}
assign global:result.mustBeTrue[2] = {global:test.string2|strCompare contains}
must-throw eval nop {global:result.mustBeTrue|map assert equals int 0}
eval nop {global:result.mustBeTrue|map assert equals int 1}

# must be false
assign global:result.mustBeTrue[0] = {global:test.string1|strCompare contains Hello World}
assign global:result.mustBeTrue[1] = {global:test.string2|strCompare contains HelloWorld}
assign global:result.mustBeTrue[2] = {global:test.string1|strCompare contains}
eval nop {global:result.mustBeTrue|map assert equals int 0}
must-throw eval nop {global:result.mustBeTrue|map assert equals int 1}

exit