# Testing string equality comparison

# Setup test strings
set test.string1 HelloWorldHello
set test.string2 Hello World, Hello Nebulite!
set test.string3

# count appearance and verify

# must be true
assign global:result.mustBeTrue[0] = {global:test.string1|strCompare equals HelloWorldHello}
assign global:result.mustBeTrue[1] = {global:test.string2|strCompare equals Hello World, Hello Nebulite!}
assign global:result.mustBeTrue[2] = {global:test.string3|strCompare equals}
must-throw eval nop {global:result.mustBeTrue|map assert equals int 0}
eval nop {global:result.mustBeTrue|map assert equals int 1}

# must be false
assign global:result.mustBeTrue[0] = {global:test.string1|strCompare equals HelloWorld}
assign global:result.mustBeTrue[1] = {global:test.string2|strCompare equals HelloWorld, Hello Nebulite!}
assign global:result.mustBeTrue[2] = {global:test.string3|strCompare equals HelloWorld}
eval nop {global:result.mustBeTrue|map assert equals int 0}
must-throw eval nop {global:result.mustBeTrue|map assert equals int 1}

exit