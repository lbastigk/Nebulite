set global:triggerCount = 0

# This will trigger
if $(1) then assign global:triggerCount += 1
if $(1) assign global:triggerCount += 1
if $(1 + 1) then assign global:triggerCount += 1

eval nop {global:triggerCount|assert equals int 3}

# This will not trigger
if $(0 + 0) then assert $(0)
if $(0) assert $(0) # This will not trigger either
if $(0) then assert $(0) # This will not trigger