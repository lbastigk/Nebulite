set-fps 60

# Open console, type some text and press enter
# Then we type text without entering
wait 15
console open
console autotype text echo TEST1
console autotype enter
console autotype text echo TEST2
console autotype wait 500
console autotype close
console autotype execute
wait 15

# Second command should be in the text input box, not executed:
echo ----- TEST2 still in text input box -----

# We open the console again, press enter to execute the command,
# then press up to get the previous command and enter to execute it again
wait 15
console open
console autotype enter
console autotype up
console autotype enter
console autotype wait 500
console autotype close # Required, as wait commands will not execute until the console is closed
console autotype execute
wait 15

# Test if clearing the autotype queue works, this part will produce no output:
wait 15
console open
console autotype enter
console autotype up
console autotype enter
console autotype wait 500
console autotype close
console autotype clear # All previous autotype commands should be cleared, so no command should be executed
console autotype execute # We execute the autotype queue, but it should be empty, so no command should be executed
console autotype close # Finally, we close the console for real
console autotype execute
wait 15

# All done, we should see:
# TEST1
# ----- TEST2 still in text input box -----
# TEST2
# TEST2

exit